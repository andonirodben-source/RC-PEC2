#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/txony/ontologies/2026/3/untitled-ontology-9#isSubclassifiedUnder
:isSubclassifiedUnder rdf:type owl:ObjectProperty ,
                               owl:TransitiveProperty .


#################################################################
