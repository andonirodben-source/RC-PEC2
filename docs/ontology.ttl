@prefix : <http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#> .

<http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito> rdf:type owl:Ontology ;
                                                                                      <http://purl.org/dc/terms/abstract> "This ontology models semantically the EUDAMED cataloge, including devices, manufacturers, identified risks, incidents and security corrective actions." ;
                                                                                      <http://purl.org/dc/terms/contributor> " Andoni Rodriguez Benito" ;
                                                                                      <http://purl.org/dc/terms/created> "2026-04-26"^^xsd:date ;
                                                                                      <http://purl.org/dc/terms/creator> " Andoni Rodriguez Benito" ;
                                                                                      <http://purl.org/dc/terms/description> "An ontology about the european cataloge of high risk medical devices and in vitro diagnosis devices, inside the regulatory framework MDR (EU 2017/745) and IVDR (EU 2017/746)" ;
                                                                                      <http://purl.org/dc/terms/title> " RC PEC2 Ontology" ;
                                                                                      rdfs:label "RC-PEC2-AndoniRodriguezBenito" ;
                                                                                      owl:versionInfo "0.0.1" ;
                                                                                      <https://w3id.org/widoco/vocab#introduction> "The goal of the ontology is to allow the accurate share of data among manufacturers, regulatory entities, hospitals and patients." .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/abstract
<http://purl.org/dc/terms/abstract> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/contributor
<http://purl.org/dc/terms/contributor> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/introduction
<http://purl.org/dc/terms/introduction> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#sameAs
rdfs:sameAs rdf:type owl:AnnotationProperty .


###  https://w3id.org/widoco/vocab#introduction
<https://w3id.org/widoco/vocab#introduction> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#affectsDevice
:affectsDevice rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf owl:topObjectProperty ;
               rdfs:domain :Incident ;
               rdfs:range :Device ;
               rdfs:comment "Assigns a device to an incident." ;
               rdfs:label "Affects the device" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#affectsDeviceType
:affectsDeviceType rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf owl:topObjectProperty ;
                   rdfs:domain :Risk ;
                   rdfs:range :Device ;
                   rdfs:comment "Assigns a device type to a risk." ;
                   rdfs:label "Affects the device type" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#affectsPatientWithSex
:affectsPatientWithSex rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range :Sex ;
                       rdfs:comment "Assigns a biological sex of a patient to an incident." ;
                       rdfs:label "Affects patients of sex" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#appliesTo
:appliesTo rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdf:type owl:FunctionalProperty ;
           rdfs:domain :CorrectiveAction ;
           rdfs:range :Incident ;
           rdfs:comment "Assigns an incident to the corrective action to mitigate it." ;
           rdfs:label "Corrective action applies to" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#belongsToRiskCategory
:belongsToRiskCategory rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty ;
                       rdf:type owl:FunctionalProperty ;
                       rdfs:domain :Risk ;
                       rdfs:range :RiskCategory ;
                       rdfs:comment "Assigns a risk category to a risk." ;
                       rdfs:label "Assigned risk category" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#doneAtGeographicalLocation
:doneAtGeographicalLocation rdf:type owl:ObjectProperty ;
                            rdfs:subPropertyOf owl:topObjectProperty ;
                            rdfs:domain :CorrectiveAction ;
                            rdfs:range :GeographicalLocation ;
                            rdfs:comment "Assigns a location to a corrective action." ;
                            rdfs:label "Corrective action carried out at" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#hasStatus
:hasStatus rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdf:type owl:FunctionalProperty ;
           rdfs:domain :CorrectiveAction ;
           rdfs:range :CorrectiveActionStatus ;
           rdfs:comment "Assigns a status to a corrective action." ;
           rdfs:label "Corrective action has status" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#inRegulatoryFrame
:inRegulatoryFrame rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf owl:topObjectProperty ;
                   rdf:type owl:FunctionalProperty ;
                   rdfs:domain :Device ;
                   rdfs:range :RegulatoryFrame ;
                   rdfs:comment "Assigns a regulatory frame to a device." ;
                   rdfs:label "Is within the regulatory frame" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#involvesRisk
:involvesRisk rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :Incident ;
              rdfs:range :Risk ;
              rdfs:comment "Assigns a risk to an incident." ;
              rdfs:label "Involves the risk" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#locatedAt
:locatedAt rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdf:type owl:FunctionalProperty ;
           rdfs:domain :Manufacturer ;
           rdfs:range :Country ;
           rdfs:comment "Assigns a geographical location to a manufacturer." ;
           rdfs:label "Located at geographical location" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#manufacturedBy
:manufacturedBy rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty ;
                rdf:type owl:FunctionalProperty ;
                rdfs:domain :Device ;
                rdfs:range :Manufacturer ;
                rdfs:comment "Assigns a manufacturer to the device they produced." ;
                rdfs:label "Device manufactured by" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#occursWithProbability
:occursWithProbability rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty ;
                       rdf:type owl:FunctionalProperty ;
                       rdfs:domain :Risk ;
                       rdfs:range :OccurrenceProbability ;
                       rdfs:comment "Assigns an occurrence probability to a risk." ;
                       rdfs:label "Occurrence probability" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#ofRiskClass
:ofRiskClass rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain :Device ;
             rdfs:range :RiskClass ;
             rdfs:comment "Assigns a risk class to a device." ;
             rdfs:label "Assigned risk class" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#ofRiskSeverity
:ofRiskSeverity rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty ;
                rdf:type owl:FunctionalProperty ;
                rdfs:domain :Risk ;
                rdfs:range :RiskSeverity ;
                rdfs:comment "Assigns a risk severity to a risk." ;
                rdfs:label "Assigned risk severity" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#reportedAt
:reportedAt rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            rdf:type owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range :GeographicalLocation ;
            rdfs:comment "Assigns a geographical location to an incident." ;
            rdfs:label "Reported at location" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#reportedBy
:reportedBy rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            rdf:type owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range :Manufacturer ;
            rdfs:comment "Assigns a manufacturer to an incident as the one who reported it." ;
            rdfs:label "Incident reported by" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#reportsTo
:reportsTo rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdf:type owl:FunctionalProperty ;
           rdfs:domain :Manufacturer ;
           rdfs:range :CompetentAuthority ;
           rdfs:comment "Assigns a competent authority to report to, to a manufacturer." ;
           rdfs:label "Manufacturer reports to" .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#caActionDate
:caActionDate rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain :CorrectiveAction ;
              rdfs:range xsd:date ;
              rdfs:comment "Date when the corrective action starts." ;
              rdfs:label "Corrective action date" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#caClosureDate
:caClosureDate rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf owl:topDataProperty ;
               rdfs:domain :CorrectiveAction ;
               rdfs:range xsd:date ;
               rdfs:comment "Date when the corrective action is considered finished." ;
               rdfs:label "Corrective action closure date" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#caDevicesAffected
:caDevicesAffected rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf owl:topDataProperty ;
                   rdfs:domain :CorrectiveAction ;
                   rdfs:range xsd:integer ;
                   rdfs:comment "Number of devices affected by the corrective action." ;
                   rdfs:label "Corrective action affected devices" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#caEudamedRef
:caEudamedRef rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain :CorrectiveAction ;
              rdfs:range xsd:string ;
              rdfs:comment "Eudamed reference for the corrective action." ;
              rdfs:label "Corrective action Eudamed Reference" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#caScope
:caScope rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf owl:topDataProperty ;
         rdfs:domain :CorrectiveAction ;
         rdfs:range xsd:string ;
         rdfs:comment "Scope of the corrective action." ;
         rdfs:label "Corrective action scope" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#dvIntendedPurpose
:dvIntendedPurpose rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf owl:topDataProperty ;
                   rdfs:domain :Device ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Purpose for which the medical device was intended." ;
                   rdfs:label "Medical device Intended purpose" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#dvIsActive
:dvIsActive rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Indicates whether the medical device is active." ;
            rdfs:label "Medical device is active?" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#dvIsImplantable
:dvIsImplantable rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf owl:topDataProperty ;
                 rdfs:domain :Device ;
                 rdfs:range xsd:boolean ;
                 rdfs:comment "Indicates whether the medical device is implantable." ;
                 rdfs:label "Medical device is implantable?" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#dvIsIvd
:dvIsIvd rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf owl:topDataProperty ;
         rdfs:domain :Device ;
         rdfs:range xsd:boolean ;
         rdfs:comment "Indicates whether the medical device is a in vitro diagnostics device." ;
         rdfs:label "Medical device is ivd?" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#dvIsReusable
:dvIsReusable rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain :Device ;
              rdfs:range xsd:boolean ;
              rdfs:comment "Indicates whether the medical device is reusable." ;
              rdfs:label "Medical device is reusable?" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#dvUdiDi
:dvUdiDi rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf owl:topDataProperty ;
         rdfs:domain :Device ;
         rdfs:range xsd:string ;
         rdfs:comment "Unique Device Identifier for the medical device." ;
         rdfs:label "Medical device unique device identifier" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#incCorrectiveActionTaken
:incCorrectiveActionTaken rdf:type owl:DatatypeProperty ;
                          rdfs:subPropertyOf owl:topDataProperty ;
                          rdfs:domain :Incident ;
                          rdfs:range xsd:boolean ;
                          rdfs:comment "Indicates whether a correction action was taken on the incident." ;
                          rdfs:label "Incident correction action taken?" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#incDetectionDate
:incDetectionDate rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf owl:topDataProperty ;
                  rdfs:domain :Incident ;
                  rdfs:range xsd:date ;
                  rdfs:comment "Date when the incident was detected." ;
                  rdfs:label "Incident detection date" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#incEudamedIncidentRef
:incEudamedIncidentRef rdf:type owl:DatatypeProperty ;
                       rdfs:subPropertyOf owl:topDataProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:string ;
                       rdfs:comment "Eudamed reference assigned to the incident." ;
                       rdfs:label "Incident Eudamed reference" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#incEventDate
:incEventDate rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain :Incident ;
              rdfs:range xsd:date ;
              rdfs:comment "Date when the incident took place." ;
              rdfs:label "Incident event date" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#incOutcome
:incOutcome rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf owl:topDataProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "Outcome of the incident." ;
            rdfs:label "Incident outcome" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#incPatientAge
:incPatientAge rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf owl:topDataProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:integer ;
               rdfs:comment "Age of the patient involved in the incident." ;
               rdfs:label "Incident patient age" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#incReportDate
:incReportDate rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf owl:topDataProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:date ;
               rdfs:comment "Date when the incident was reported." ;
               rdfs:label "Incident report date" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#mnAuthorizationNumber
:mnAuthorizationNumber rdf:type owl:DatatypeProperty ;
                       rdfs:subPropertyOf owl:topDataProperty ;
                       rdfs:domain :Manufacturer ;
                       rdfs:range xsd:string ;
                       rdfs:comment "Authorization number of the manufacturer." ;
                       rdfs:label "Manufacturer authorization number" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#mnContactEmail
:mnContactEmail rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain :Manufacturer ;
                rdfs:range xsd:string ;
                rdfs:comment "Email address for contacting the manufacturer." ;
                rdfs:label "Manufacturer contact email" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#mnEudamedSrn
:mnEudamedSrn rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf owl:topDataProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range xsd:string ;
              rdfs:comment "Eudamed serial number assigned to the manufacturer." ;
              rdfs:label "Manufacturer Eudamed serial number" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#rkImdrfCode
:rkImdrfCode rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:domain :Risk ;
             rdfs:range xsd:string ;
             rdfs:comment "Risk definition according to the International Medical Device Regulators Forum." ;
             rdfs:label "Risk definition code" .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#ActiveDevice
:ActiveDevice rdf:type owl:Class ;
              rdfs:subClassOf :Device ;
              rdfs:comment "A device that has an active work." ;
              rdfs:label "Active device" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#ActiveImplant
:ActiveImplant rdf:type owl:Class ;
               rdfs:subClassOf :Device ;
               rdfs:comment "A device that must be implanted and has an active work" ;
               rdfs:label "Active implant" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#CompetentAuthority
:CompetentAuthority rdf:type owl:Class ;
                    rdfs:comment "The regulatory authority that has the competence to control the regulations on the products." ;
                    rdfs:label "Competent authority" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#ContaminationRisk
:ContaminationRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "Risk of the device being contaminated, rendering it to malfunction." ;
                   rdfs:label "Contamination risk" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#CorrectiveAction
:CorrectiveAction rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty :hasStatus ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass :CorrectiveActionStatus
                                  ] ;
                  rdfs:comment "Actions carried out to mitigate or fix some kind of issue." ;
                  rdfs:label "Corrective action" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#CorrectiveActionStatus
:CorrectiveActionStatus rdf:type owl:Class ;
                        rdfs:comment "Status of the corrective action that is to be/was addressed." ;
                        rdfs:label "Corrective action status" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#Country
:Country rdf:type owl:Class ;
         rdfs:subClassOf :GeographicalLocation ;
         rdfs:comment "Country of location" ;
         rdfs:label "Country" ;
         rdfs:sameAs "https://d-nb.info/standards/elementset/gnd#Country" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#CybersecurityRisk
:CybersecurityRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "Risk of data leaking due to a sofware issue." ;
                   rdfs:label "Cybersecurity risk" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :manufacturedBy ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :Manufacturer
                        ] ;
        rdfs:comment "Medical device." ;
        rdfs:label "Device" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#DiagnosticRisk
:DiagnosticRisk rdf:type owl:Class ;
                rdfs:subClassOf :Risk ;
                rdfs:comment "Risk of the device providing an inaccurate diagnosis." ;
                rdfs:label "Diagnostic risk" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#GeographicalLocation
:GeographicalLocation rdf:type owl:Class ;
                      rdfs:comment "Location of the subject." ;
                      rdfs:label "Geographical location" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#ImplantableActiveDevice
:ImplantableActiveDevice rdf:type owl:Class ;
                         rdfs:subClassOf :Device ;
                         rdfs:comment "A device that can be implanted and has an active work." ;
                         rdfs:label "Implantable active device" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#ImplantableDevice
:ImplantableDevice rdf:type owl:Class ;
                   rdfs:subClassOf :Device ;
                   rdfs:comment "A device that can be implanted." ;
                   rdfs:label "Implantable device" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#InSituCorrection
:InSituCorrection rdf:type owl:Class ;
                  rdfs:subClassOf :CorrectiveAction ;
                  rdfs:comment "Some kind of correction/fix is carried out in place." ;
                  rdfs:label "In situ correction" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         rdfs:subClassOf :Device ;
                         rdfs:comment "A device for in vitro diagnostics." ;
                         rdfs:label "In vitro diagnostic device" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#Incident
:Incident rdf:type owl:Class ;
          rdfs:comment "Detected incident with a medical device." ;
          rdfs:label "Incident" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#InfectionRisk
:InfectionRisk rdf:type owl:Class ;
               rdfs:subClassOf :Risk ;
               rdfs:comment "Risk of infection derived from the use of the device." ;
               rdfs:label "Infection risk" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#InjuryRisk
:InjuryRisk rdf:type owl:Class ;
            rdfs:subClassOf :Risk ;
            rdfs:comment "Risk of injury for the user/patient." ;
            rdfs:label "Injury risk" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#InterferenceRisk
:InterferenceRisk rdf:type owl:Class ;
                  rdfs:subClassOf :Risk ;
                  rdfs:comment "Risk of interference with other medical devices." ;
                  rdfs:label "Interference risk" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#MalfunctionRisk
:MalfunctionRisk rdf:type owl:Class ;
                 rdfs:subClassOf :Risk ;
                 rdfs:comment "Risk of the device malfunctioning." ;
                 rdfs:label "Malfunction risk" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:comment "Medical device manufacturer." ;
              rdfs:label "Manufacturer" ;
              rdfs:sameAs "https://d-nb.info/standards/elementset/gnd#manufacturer" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#MaterialRisk
:MaterialRisk rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "Risk caused by the materials in the device or produced from its usage." ;
              rdfs:label "Material risk" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#NearMissIncident
:NearMissIncident rdf:type owl:Class ;
                  rdfs:subClassOf :Incident ;
                  owl:disjointWith :SeriousIncident ;
                  rdfs:comment "Unplanned event that does not cause injury, illness, or damage, but had the potential to do so." ;
                  rdfs:label "Near miss incident" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#OccurrenceProbability
:OccurrenceProbability rdf:type owl:Class ;
                       rdfs:comment "Probability of something occurring." ;
                       rdfs:label "Ocurrence probability" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#RadiationRisk
:RadiationRisk rdf:type owl:Class ;
               rdfs:subClassOf :Risk ;
               rdfs:comment "Risk of getting a higher radiation level from the device than that considered safe." ;
               rdfs:label "Radiation risk" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :CorrectiveAction ;
        rdfs:comment "A recall order is issued to remove the products from the market." ;
        rdfs:label "Product recall" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#RegulatoryFrame
:RegulatoryFrame rdf:type owl:Class ;
                 rdfs:comment "Regulatory framework inside the EU." ;
                 rdfs:label "Regulatory framework" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#Risk
:Risk rdf:type owl:Class ;
      rdfs:comment "Risk that a medical device can entail." ;
      rdfs:label "Risk" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#RiskCategory
:RiskCategory rdf:type owl:Class ;
              rdfs:comment "Category of the risk that a medical device may entail." ;
              rdfs:label "Risk category" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#RiskClass
:RiskClass rdf:type owl:Class ;
           rdfs:comment "Classification of the assessed risk." ;
           rdfs:label "Risk class" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#RiskSeverity
:RiskSeverity rdf:type owl:Class ;
              rdfs:comment "Indicates how severe the risk associated to the device is." ;
              rdfs:label "Risk severity" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#SafetyAlert
:SafetyAlert rdf:type owl:Class ;
             rdfs:subClassOf :CorrectiveAction ;
             rdfs:comment "An alert is issued to every user of the product." ;
             rdfs:label "Safety alert" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#SelfTestDevice
:SelfTestDevice rdf:type owl:Class ;
                rdfs:subClassOf :Device ;
                rdfs:comment "A test for the patient to execute by theirselves." ;
                rdfs:label "Self test device" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#SeriousIncident
:SeriousIncident rdf:type owl:Class ;
                 rdfs:subClassOf :Incident ;
                 rdfs:comment "Serious incident of a medical device." ;
                 rdfs:label "Serious incident" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#Sex
:Sex rdf:type owl:Class ;
