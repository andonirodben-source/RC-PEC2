     rdfs:label "Sex" ;
     rdfs:sameAs "https://d-nb.info/standards/elementset/gnd#Gender" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#SingleUseDevice
:SingleUseDevice rdf:type owl:Class ;
                 rdfs:subClassOf :Device ;
                 rdfs:comment "A device that can only be used once." ;
                 rdfs:label "Single user device" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#SoftwareRisk
:SoftwareRisk rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "Risk of malfunctioning due to a sofware issue." ;
              rdfs:label "Software risk" .


###  http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#UserNotice
:UserNotice rdf:type owl:Class ;
            rdfs:subClassOf :CorrectiveAction ;
            rdfs:comment "The users are notified about the issue." ;
            rdfs:label "User notice" .


