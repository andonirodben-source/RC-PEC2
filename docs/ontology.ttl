#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :ActiveDevice
                :ActiveImplant
                :ImplantableActiveDevice
                :ImplantableDevice
                :InVitroDiagnosticDevice
                :SelfTestDevice
                :SingleUseDevice
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :ContaminationRisk
                :CybersecurityRisk
                :DiagnosticRisk
                :InfectionRisk
                :InjuryRisk
                :InterferenceRisk
                :MalfunctionRisk
                :MaterialRisk
                :RadiationRisk
                :SoftwareRisk
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :InSituCorrection
                :Recall
                :SafetyAlert
                :UserNotice
              )
] .


