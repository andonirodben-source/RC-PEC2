<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#"
     xml:base="http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:vocab="https://w3id.org/widoco/vocab#"
     xmlns:RC_PEC2_Andoni_Rodriguez_Benito="http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/txony/ontologies/2026/3/RC_PEC2_Andoni_Rodriguez_Benito">
        <terms:abstract>This ontology models semantically the EUDAMED cataloge, including devices, manufacturers, identified risks, incidents and security corrective actions.</terms:abstract>
        <terms:contributor> Andoni Rodriguez Benito</terms:contributor>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-26</terms:created>
        <terms:creator> Andoni Rodriguez Benito</terms:creator>
        <terms:description>An ontology about the european cataloge of high risk medical devices and in vitro diagnosis devices, inside the regulatory framework MDR (EU 2017/745) and IVDR (EU 2017/746)</terms:description>
        <terms:title> RC PEC2 Ontology</terms:title>
        <rdfs:label>RC-PEC2-AndoniRodriguezBenito</rdfs:label>
        <owl:versionInfo>0.0.1</owl:versionInfo>
        <vocab:introduction>The goal of the ontology is to allow the accurate share of data among manufacturers, regulatory entities, hospitals and patients.</vocab:introduction>
    </owl:Ontology>
    


