  "http://purl.org/dc/terms/description" : [ {
    "@value" : "An ontology about the european cataloge of high risk medical devices and in vitro diagnosis devices, inside the regulatory framework MDR (EU 2017/745) and IVDR (EU 2017/746)"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@value" : "High risk medical and in-vitro diagnostics devices (MDR and IVDR compliant)"
